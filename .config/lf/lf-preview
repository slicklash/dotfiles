#!/bin/sh

file="$1"
w="$2"
h="$3"
x="$4"
y="$5"
mode="$6"

# Reserve the pane's top row for lf's "loading" text so clearing it can't clip
# the image. Shift the drawable area down one row.
[ "$h" -gt 1 ] 2>/dev/null && { y=$((y + 1)); h=$((h - 1)); }

# Cached derived previews (video/pdf thumbnails, cropped images) can hold sensitive
# content, so keep them private and bounded: umask 077 -> 0600 files; TMPDIR is
# per-user and cleared on reboot (and excluded from Time Machine on macOS), unlike
# ~/.cache; prune_cache keeps only the newest entries so they don't accumulate.
umask 077
CACHE_DIR="${TMPDIR:-/tmp}/lf-preview-cache"
prune_cache() { ls -t "$CACHE_DIR" 2>/dev/null | tail -n +201 | while read -r f; do rm -f "$CACHE_DIR/$f"; done; }

# Serialise tty writes across the previewers lf spawns during fast navigation
# (mkdir = atomic mutex; macOS has no flock). Steal a lock held >1s in case lf
# SIGKILLed the holder before it released.
LOCK="${TMPDIR:-/tmp}/lf-tty-${TMUX_PANE:-shared}.lock"
lock() {
    i=0
    while ! mkdir "$LOCK" 2>/dev/null; do
        i=$((i + 1)); [ "$i" -ge 100 ] && { rm -rf "$LOCK"; i=0; }
        sleep 0.01
    done
    trap 'unlock' EXIT INT TERM HUP
}
unlock() { rmdir "$LOCK" 2>/dev/null; trap - EXIT INT TERM HUP; }

# Remove the kitty image: free it by id and erase its Unicode-placeholder cells
# (lf never repaints them). One printf so the batch can't be split; CUP is 1-based
# vs lf's 0-based x/y, hence +1.
emit_clear() {
    lock
    if [ -n "$TMUX" ]; then
        seq='\033Ptmux;\033\033_Ga=d,d=I,i=1\033\033\134\033\134'
        r=$((y + 1)); end=$((y + h + 1)); c=$((x + 1))
        while [ "$r" -lt "$end" ]; do seq="$seq\033[${r};${c}H\033[K"; r=$((r + 1)); done
        printf "$seq" >/dev/tty
    else
        printf '\033_Ga=d,d=A\033\134' >/dev/tty
    fi
    unlock
}

# This script is set as BOTH the previewer and the cleaner. lf gives the cleaner
# the *next* filename as $6 (vs "preview"/"preload" for the previewer); in that
# mode just clear the image being left and exit. The cleaner is what removes the
# image when you move to a cached text preview or a directory -- there lf renders
# without calling the previewer, so the previewer clearing itself wouldn't run.
case "$mode" in
    preview|preload) ;;
    *) emit_clear; exit 0 ;;
esac

mime_type=$(file -Lb --mime-type -- "$file" 2>/dev/null)

# Only the file you land on should draw: each previewer records its target and
# draw() bails (after taking the lock) if a newer one has superseded it.
WANT="${LOCK}.want"
stale() { [ "$(cat "$WANT" 2>/dev/null)" != "$file" ]; }

# kitten flags: -n (no trailing newline, else it scrolls a row), --scale-up
# (enlarge small images to fill the pane), --image-id 1 (reuse one id). In tmux
# add --unicode-placeholder (cells the cleaner can erase) and --use-window-size,
# because tmux hides the cell pixel size and kitten would under-scale -- feed it
# the pane geometry. Cell px is a one-time measurement of this Ghostty font
# (284 cols=5112px, 65 rows=2628px); re-measure (`kitten icat --print-window-size`
# + tput cols/lines) if the font size changes.
draw() {
    [ "$mode" = "preload" ] && exit 1
    up=""
    if [ -n "$TMUX" ]; then
        eval "$(tmux display -p -t "$TMUX_PANE" 'PW=#{pane_width};PH=#{pane_height}')"
        up="--unicode-placeholder --use-window-size $PW,$PH,$((PW*5112/284)),$((PH*2628/65))"
    fi
    lock
    stale && { unlock; exit 1; }
    kitten icat --stdin no --transfer-mode memory --image-id 1 -n --scale-up $up \
        --place "${w}x${h}@${x}x${y}" "$1" </dev/null >/dev/tty
    unlock
    exit 1  # no cache, so reselecting re-draws
}

hash() {
    if command -v realpath >/dev/null 2>&1; then
        real_path=$(realpath "$1")
    else
        real_path="$1"
    fi

    if [ "$(uname)" = "Darwin" ]; then
        stat_str=$(stat -f "%N%i%z%m" "$real_path")
    else
        stat_str=$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' "$real_path")
    fi

    if command -v sha256sum >/dev/null 2>&1; then
        hashed_name=$(printf "%s" "$stat_str" | sha256sum | awk '{print $1}')
    else
        hashed_name=$(printf "%s" "$stat_str" | shasum -a 256 | awk '{print $1}')
    fi

    cache="$CACHE_DIR/${hashed_name}.jpg"
}

cache_preview() {
    if [ ! -f "$cache" ]; then
        mkdir -p "$(dirname "$cache")"; prune_cache
        "$@"
    fi
    [ -s "$cache" ] && draw_fit_width "$cache"
}

# Seek to 10% to skip black intro frames; ffmpeg decodes directly (no player).
ffmpeg_thumb() {
    dur=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$1" 2>/dev/null)
    ss=$(awk -v d="$dur" 'BEGIN { s = (d > 0) ? d * 0.1 : 0; printf "%.2f", s }')
    ffmpeg -y -ss "$ss" -i "$1" -frames:v 1 -q:v 3 "$2" >/dev/null 2>&1
}

# Fill the pane WIDTH: kitten only fits-within, so crop a too-tall image to the
# pane aspect (keeping the top) so it fills the width instead of sitting narrow.
# Cached per pane size; wide images and the no-magick case fall through to draw.
draw_fit_width() {
    src="$1"
    pw=$((w * 5112 / 284)); ph=$((h * 2628 / 65))   # pane px (cells x cell px)
    eval "$(sips -g pixelWidth -g pixelHeight "$src" 2>/dev/null \
        | awk '/pixelWidth/{print "iW="$2} /pixelHeight/{print "iH="$2}')"
    if [ -n "$iW" ] && [ -n "$iH" ] && [ "$((iW * ph))" -lt "$((iH * pw))" ]; then
        croph=$((iW * ph / pw))
        hash "$src"; cache="${cache%.jpg}-${w}x${h}.jpg"
        if [ ! -s "$cache" ] && command -v magick >/dev/null 2>&1; then
            mkdir -p "$(dirname "$cache")"; prune_cache
            magick "$src" -gravity North -crop "${iW}x${croph}+0+0" +repage "$cache" 2>/dev/null
        fi
        [ -s "$cache" ] && { draw "$cache"; return; }
    fi
    draw "$src"
}

# Record the latest request (for stale()). Clearing the previous image is handled
# by the cleaner above when you leave it, so the previewer only draws.
[ "$mode" != "preload" ] && { printf '%s\n' "$file" > "$WANT.$$" && mv -f "$WANT.$$" "$WANT"; } 2>/dev/null

case "$mime_type" in
    image/*)
        draw_fit_width "$file"
        ;;
    video/*)
        if command -v ffmpeg >/dev/null 2>&1; then
            hash "$file"
            cache_preview ffmpeg_thumb "$file" "$cache"
        fi
        ;;
    application/pdf)
        if command -v pdftoppm >/dev/null 2>&1; then
            hash "$file"
            cache_preview pdftoppm -f 1 -singlefile -jpeg "$file" "${cache%.*}"
        fi
        ;;
    application/zip|application/x-tar|application/gzip|application/x-bzip2|application/x-xz|application/x-rar|application/x-7z-compressed)
        if command -v atool >/dev/null 2>&1; then
            exec atool -l "$file"
        elif command -v bsdtar >/dev/null 2>&1; then
            exec bsdtar -tf "$file"
        elif command -v unzip >/dev/null 2>&1; then
            exec unzip -l "$file"
        elif command -v 7z >/dev/null 2>&1; then
            exec 7z l "$file"
        fi
        ;;
    *)
        if command -v bat >/dev/null 2>&1; then
            exec bat --style=plain --color=always --paging=never "$file"
        else
            exec cat "$file"
        fi
        ;;
esac

file -Lb -- "$file" 2>/dev/null | fold -s -w "$w"
exit 0
